<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background">

    <!-- 1. FOTO FULL BLEED -->
    <ImageView
        android:id="@+id/manifestation_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/manifestation_image_description"
        android:src="@drawable/placeholder_manifestation" />

    <!-- 2. GRADIENTE DE LEGIBILIDAD (Corregido: Usamos FrameLayout en vez de View) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_overlay" />

    <!-- 3. CONTENIDO FLOTANTE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_sparkle"
                android:tint="#FFFFFF"
                android:alpha="0.8" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="SASPER VISION"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:textColor="#CCFFFFFF"
                android:shadowColor="#80000000"
                android:shadowRadius="3"
                android:shadowDy="1" />

            <TextView
                android:id="@+id/manifestation_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="1/5"
                android:textSize="11sp"
                android:textColor="#99FFFFFF"
                android:fontFamily="sans-serif" />

            <!-- Espaciador horizontal (Corregido: Usamos FrameLayout en vez de View) -->
            <FrameLayout 
                android:layout_width="0dp" 
                android:layout_height="0dp" 
                android:layout_weight="1" />

            <!-- Micro Controles Superiores -->
            <ImageButton
                android:id="@+id/btn_refresh"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:background="@drawable/glass_button_bg"
                android:src="@drawable/ic_refresh"
                android:padding="6dp"
                android:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btn_open_app"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/glass_button_bg"
                android:src="@drawable/ic_open_app"
                android:padding="6dp"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Espacio flexible central (Corregido: Usamos FrameLayout en vez de View) -->
        <FrameLayout 
            android:layout_width="match_parent" 
            android:layout_height="0dp" 
            android:layout_weight="1" />

        <!-- BOTTOM CONTENT (Textos y Navegación) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <!-- Textos a la izquierda -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/manifestation_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Casa en la playa"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.02"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:shadowColor="#99000000"
                    android:shadowRadius="4"
                    android:shadowDy="2" />

                <TextView
                    android:id="@+id/manifestation_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Un lugar para descansar"
                    android:textColor="#D9FFFFFF"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"
                    android:shadowColor="#99000000"
                    android:shadowRadius="3"
                    android:shadowDy="1" />
                
                <TextView
                    android:id="@+id/daily_manifestation_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Has manifestado 3 veces hoy"
                    android:textColor="#FFD700"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="6dp"
                    android:shadowColor="#99000000"
                    android:shadowRadius="4"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Controles a la derecha -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="12dp">

                <ImageButton
                    android:id="@+id/btn_previous"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/glass_button_bg"
                    android:src="@drawable/ic_chevron_left"
                    android:tint="#FFFFFF" />

                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/glass_button_bg"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- EFECTO DE DESTELLO AL VISUALIZAR -->
    <FrameLayout
        android:id="@+id/visualization_effect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#90FFD700"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Manifestado!"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:fontFamily="sans-serif-black"
                android:shadowColor="#40000000"
                android:shadowDy="2"
                android:shadowRadius="8" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>