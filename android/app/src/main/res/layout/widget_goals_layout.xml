<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:theme="@style/Theme.AppWidget">

    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- HEADER MINIMALISTA (Estilo iOS) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <!-- Textos a la izquierda -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MIS METAS"
                    android:textColor="?attr/colorPrimary"
                    android:fontFamily="sans-serif-black"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/widget_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progreso de Ahorro"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="16sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Controles a la derecha (Botones de Cristal) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/widget_goal_item_background"
                android:padding="4dp">

                <ImageButton
                    android:id="@+id/refresh_button"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_refresh"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/refresh_widget" />

                <ImageButton
                    android:id="@+id/add_goal_button"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_add"
                    android:tint="?attr/colorPrimary"
                    android:layout_marginStart="4dp"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/add_goal" />
            </LinearLayout>
        </LinearLayout>

        <!-- CONTENIDO: LISTA O ESTADO VACÍO -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ListView con Scroll, sin divisores duros -->
            <ListView
                android:id="@+id/goals_list_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@android:color/transparent"
                android:dividerHeight="10dp"
                android:scrollbars="none"
                android:clipToPadding="false" />

            <!-- Estado Vacío -->
            <LinearLayout
                android:id="@+id/empty_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:background="@drawable/widget_goal_item_background"
                tools:visibility="visible">
                
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:alpha="0.4"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Toca para añadir una meta"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="13sp"
                    android:alpha="0.7"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>