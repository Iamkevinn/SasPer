<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_next_payment_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_payment_card_background"
    android:theme="@style/Theme.AppWidget">

    <!-- TODO EL CONTENEDOR ES CLIQUEABLE PARA ABRIR LA APP -->
    <LinearLayout
        android:id="@+id/widget_next_payment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground">

        <!-- HEADER MINIMALISTA (Eyebrow) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRÓXIMO PAGO"
                    android:textColor="?attr/colorPrimary"
                    android:fontFamily="sans-serif-black"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <!-- Botón de recarga sutil (Opcional, pero útil) -->
            <ImageButton
                android:id="@+id/refresh_button"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_refresh"
                android:tint="?attr/colorOnSurfaceVariant"
                android:padding="4dp"
                android:alpha="0.6"
                android:contentDescription="@string/refresh_payment_description" />
        </LinearLayout>

        <!-- CONTENIDO PRINCIPAL -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- VISTA CON PAGO PENDIENTE -->
            <LinearLayout
                android:id="@+id/next_payment_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:visibility="visible">

                <!-- Monto Gigante (Protagonista) -->
                <TextView
                    android:id="@+id/tv_next_payment_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="sans-serif-black"
                    android:textSize="32sp"
                    android:letterSpacing="-0.03"
                    tools:text="$85.000" />

                <!-- Concepto (Qué se paga) -->
                <TextView
                    android:id="@+id/tv_next_payment_concept"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"
                    tools:text="Netflix Premium" />

                <!-- Subtítulo (Cuota / Días restantes) -->
                <TextView
                    android:id="@+id/tv_payment_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="sans-serif"
                    android:textSize="13sp"
                    android:alpha="0.8"
                    android:layout_marginTop="2dp"
                    tools:text="Cuota 3 de 12 · Vence mañana" />
            </LinearLayout>

            <!-- EMPTY STATE (Limpio y Elegante) -->
            <LinearLayout
                android:id="@+id/empty_view_next_payment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                tools:visibility="gone">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_check_circle"
                    android:tint="?attr/colorPrimary"
                    android:alpha="0.8"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Todo al día"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="15sp" />
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>
</FrameLayout>